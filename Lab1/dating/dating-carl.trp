            val profile = (lev, "Hacker" raisedTo lev, 30 raisedTo lev, true raisedTo lev, ["malware"] raisedTo lev)
            val _ = send(whereis ("@dating-server", "datingServer"), ("NEWPROFILE", (profile, fake_agent, self())))
        in ()
        end

    fun received () =       
        let
            val received_profile = receive [hn ("LEAKED", rcv) => 
                                    rcv
                                ]
            val _ = print ("LEAKED profile: ", received_profile)
        in 
            (received())
        end


    fun main () =
        let
            val receiverPID = spawn (fn () => received())
            val _ = spawn (fn () => declassify_attack(receiverPID))
        in ()
        end
in (main())
end
